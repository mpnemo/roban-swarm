[Unit]
Description=Roban Swarm Base Controller (Web UI + Fleet Management)
After=network-online.target mavlink-hub.service
Wants=mavlink-hub.service

[Service]
Type=simple
ExecStart=/opt/roban-swarm/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8080
WorkingDirectory=/opt/roban-swarm/base-controller
Restart=on-failure
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
